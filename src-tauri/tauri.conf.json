{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HomeNet",
  "version": "0.1.4",
  "identifier": "com.nowat.homenet",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HomeNet · DDNS与端口转发",
        "width": 1586,
        "height": 992,
        "minWidth": 1366,
        "minHeight": 768,
        "resizable": true,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": "",
      "windows": {
        "installMode": "quiet"
      }
    }
  }
}
